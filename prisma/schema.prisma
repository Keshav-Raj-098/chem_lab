generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ResearchStatus {
  ONGOING
  COMPLETED
  PLANNED
}

enum ResearchProjectType {
  FUNDED
  NON_FUNDED
}

model ResearchProjects {
  id              String              @id @default(uuid())
  title           String
  description     String?
  fundingAgencies String?
  investigators   String?
  contributors    String?
  duration        String?
  status          ResearchStatus      @default(PLANNED)
  type            ResearchProjectType @default(NON_FUNDED)
  amntFunded      String?
  completedOn     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([completedOn])
}

model Equipments {
  id           String   @id @default(uuid())
  name         String
  manufacturer String
  model        String
  serialNumber String
  installedOn  DateTime
  category     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GroupMembers {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  researchAreas String?
  designation   String?
  category      GroupCategory
  profileImgUrl String?
  profileLink   String?
  phoneNumber   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Awards {
  id        String    @id @default(uuid())
  body      String
  type      AwardType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Publications {
  id        String              @id @default(uuid())
  body      String
  category  PublicationCategory
  year      Int?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([category])
  @@index([year])
}

model NewsAndAnnouncements {
  id        String   @id @default(uuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



enum GroupCategory {
  POSTDOC
  PHD
  MASTERS
  UNDERGRADUATE
  FACULTY
  FACULTY_FELLOW
  ALUMNI
  STAFF
  RESEARCH_SCHOLAR
  COLLABORATOR
  OTHER
}

enum AwardType {
  GROUP_LEADER
  GROUP_MEMBER
}

enum PublicationCategory {
  PATENTS
  JOURNAL
  CONFERENCE
  PRESENTATION
  NATIONAL_REPORT
  INVITED_TALK
  BOOK
  OTHER
  PUBLICATION
}
